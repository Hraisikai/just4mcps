# ── Keycloak ──────────────────────────────────────────────────────────────────
# Base URL of your Keycloak instance (no trailing slash).
KEYCLOAK_URL=https://your-keycloak.example.com
# Keycloak realm name.
KEYCLOAK_REALM=your-realm
# OAuth2 client ID registered in Keycloak for this gateway.
KEYCLOAK_CLIENT_ID=mcp-gateway
# Client secret (for confidential clients). Leave blank for public clients.
KEYCLOAK_CLIENT_SECRET=your-client-secret
# JWT claim that contains group memberships.
KEYCLOAK_GROUPS_CLAIM=groups

# Keycloak group paths that grant admin access to the gateway (JSON list).
ADMIN_GROUPS=["/admins"]

# ── SurrealDB ─────────────────────────────────────────────────────────────────
SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_USER=root
SURREAL_PASS=changeme
SURREAL_NAMESPACE=just4mcps
SURREAL_DATABASE=mcp_gateway

# ── App ───────────────────────────────────────────────────────────────────────
# Allowed CORS origins (JSON list).
CORS_ORIGINS=["http://localhost:5173"]
# Health-check interval for upstream MCP servers (seconds).
UPSTREAM_HEALTH_INTERVAL_SECONDS=30
UPSTREAM_RECONNECT_MAX_DELAY_SECONDS=300
